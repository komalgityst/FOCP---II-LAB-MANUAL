#include <iostream>
using namespace std;

int main() {
    int A[3][3];

    cout << "Enter matrix:\n";
    for(int i=0;i<3;i++)
        for(int j=0;j<3;j++)
            cin >> A[i][j];

    cout << "Transpose Matrix:\n";
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++)
            cout << A[j][i] << " ";
        cout << endl;
    }

    return 0;
}
