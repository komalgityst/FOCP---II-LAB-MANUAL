#include <iostream>
using namespace std;

int main() {
    int num, sum = 0, rem, temp;

    cout << "Enter a number: ";
    cin >> num;

    
    temp = num;
    while(temp != 0) {
        rem = temp % 10;
        sum += rem * rem * rem;
        temp /= 10;
    }

    if(sum == num)
        cout << "Armstrong Number\n";
    else
        cout << "Not Armstrong\n";

    
    int i, s = 0;
    for(i = 1; i < num; i++) {
        if(num % i == 0)
            s += i;
    }

    if(s == num)
        cout << "Perfect Number";
    else
        cout << "Not Perfect Number";

    return 0;
}
