#include <iostream>
using namespace std;

int main() {
    int num, rev = 0, rem, temp;

    cout << "Enter ID number: ";
    cin >> num;

    temp = num;

    while(temp != 0) {
        rem = temp % 10;
        rev = rev * 10 + rem;
        temp /= 10;
    }

    if(num == rev)
        cout << "Palindrome ID";
    else
        cout << "Not a Palindrome ID";

    return 0;
}
