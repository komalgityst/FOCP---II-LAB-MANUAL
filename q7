#include <iostream>
using namespace std;

int main() {
    int s1, s2, s3;

    cout << "Enter scores of three players: ";
    cin >> s1 >> s2 >> s3;

    if(s1 > s2 && s1 > s3)
        cout << "Player 1 is the winner";
    else if(s2 > s1 && s2 > s3)
        cout << "Player 2 is the winner";
    else
        cout << "Player 3 is the winner";

    return 0;
}
