#include <iostream>
using namespace std;

int main() {
    int start, end, i, j;
    bool prime;

    cout << "Enter starting limit: ";
    cin >> start;

    cout << "Enter ending limit: ";
    cin >> end;

    for(i = start; i <= end; i++) {
        if(i < 2)
            continue;

        prime = true;

        for(j = 2; j <= i/2; j++) {
            if(i % j == 0) {
                prime = false;
                break;
            }
        }

        if(prime)
            cout << i << " ";
    }

    return 0;
}
